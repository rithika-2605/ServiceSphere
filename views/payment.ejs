<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Complete Payment - ServiceSphere</title>
    <link href="https://fonts.googleapis.com/css2?family=Sequel+Sans:wght@400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.1.1/css/all.min.css">
    <link rel="stylesheet" href="/styles/payment1.css">
    <style>
        .error-msg {
            color: #d9534f;
            font-size: 13px;
            margin-top: 4px;
        }

        input.invalid {
            border: 2px solid #d9534f;
        }

        input.valid {
            border: 2px solid #28a745;
        }

    </style>
</head>
<body>
    <div class="payment-wrapper">
        <h1 class="page-title">Complete Your Payment</h1>
        
        <div class="payment-container">
            <!-- Payment Details Section -->
            <div class="payment-details">
                <h2 class="section-title"><i class="fas fa-credit-card"></i> Payment Method</h2>
                
                <div class="payment-methods">
                    <div class="payment-method active" id="card-method">
                        <i class="fas fa-credit-card"></i>
                        <div>Card</div>
                    </div>
                    <div class="payment-method" id="paypal-method">
                        <i class="fab fa-paypal"></i>
                        <div>PayPal</div>
                    </div>
                    <div class="payment-method" id="upi-method">
                        <i class="fas fa-mobile-alt"></i>
                        <div>UPI</div>
                    </div>
                </div>
                
                <!-- Card Payment Form -->
                <div id="card-payment-form">
                    <div class="input-group">
                        <label for="cardholder">Cardholder Name</label>
                        <input type="text" id="cardholder" placeholder="As shown on card">
                    </div>
                    
                    <div class="input-group">
                        <label for="cardnumber">Card Number</label>
                        <input type="text" id="cardnumber" placeholder="1234 5678 9012 3456">
                    </div>
                    
                    <div class="card-row">
                        <div class="input-group">
                            <label for="expiry">Expiry Date</label>
                            <input type="text" id="expiry" placeholder="MM/YY">
                        </div>
                        
                        <div class="input-group">
                            <label for="cvv">CVV</label>
                            <input type="text" id="cvv" placeholder="123">
                        </div>
                    </div>
                </div>
                
                <div class="divider"></div>
                
                <h2 class="section-title"><i class="fas fa-user"></i> Billing Information</h2>
                
                <div class="input-group">
                    <label for="email">Email</label>
                    <input type="email" id="email" placeholder="your@email.com">
                </div>
                
                <div class="input-group">
                    <label for="phone">Phone</label>
                    <input type="tel" id="phone" placeholder="Your phone number">
                </div>

                <form action="/payment" method="post">
                    <input type="hidden" name="bookingId" value="<%= bookingId %>">
                    <button id="complete-payment" class="submit-btn" type="submit">Complete Payment</button>
                </form>                
                
                <div class="secure-badge">
                    <i class="fas fa-lock"></i>
                    <span>Secure Payment Processing</span>
                </div>
            </div>
            
            <!-- Order Summary Section -->
            <div class="order-summary">
                <h2 class="section-title"><i class="fas fa-clipboard-list"></i> Order Summary</h2>
                
                <div class="service-details">
                    <div class="service-item">
                        <span>Service:</span>
                        <span id="service-name"><%= serviceType %></span>
                    </div>
                    
                    <div class="service-item">
                        <span>Date:</span>
                        <span id="service-date"><%= date %></span>
                    </div>
                    
                    <div class="service-item">
                        <span>Time:</span>
                        <span id="service-time"><%= time %></span>
                    </div>
                </div>
                
                <div class="helper-details">
                    <div class="helper-avatar">
                        <i class="fas fa-user"></i>
                    </div>
                    <div>
                        <strong id="helper-name"><%= helperName %></strong>
                        <div>Service Provider</div>
                    </div>
                </div>
                
                    <div class="price-breakdown">
                        <div class="price-row">
                            <span>Service Fee</span>
                            <span id="service-fee">₹<%= price %></span>
                        </div>
                        
                        <div class="price-row">
                            <span>Platform Fee</span>
                            <span id="platform-fee">₹<%= (price * 0.1).toFixed(2) %></span>
                        </div>
                        
                        <div class="price-row">
                            <span>Tax</span>
                            <span id="tax-amount">₹<%= (price * 0.1).toFixed(2) %></span>
                        </div>
                        
                        <div class="total-row">
                            <span>Total</span>
                            <span id="total-amount">
                                ₹<%= (price + (price * 0.1) + (price * 0.1)).toFixed(2) %>
                            </span>
                        </div>
                    </div>                
                </div>                
            </div>
        </div>
    </div>
    
    <script>
    document.addEventListener('DOMContentLoaded', function () {
        const completePaymentBtn = document.getElementById('complete-payment');
        const expiryInput = document.getElementById('expiry');
        const fields = ['cardholder', 'cardnumber', 'expiry', 'cvv', 'email', 'phone'];

        // Utility: Show or remove error messages dynamically
        function showError(input, message) {
            let error = input.parentElement.querySelector('.error-msg');
            if (!error) {
                error = document.createElement('div');
                error.classList.add('error-msg');
                input.parentElement.appendChild(error);
            }
            error.textContent = message;
            input.classList.add('invalid');
        }

        function clearError(input) {
            const error = input.parentElement.querySelector('.error-msg');
            if (error) error.remove();
            input.classList.remove('invalid');
            input.classList.add('valid');
        }

        // Auto-slasher for expiry date
        expiryInput.addEventListener('input', function () {
            let value = this.value.replace(/\D/g, "");
            if (value.length >= 2) {
                this.value = value.slice(0, 2) + "/" + value.slice(2, 4);
            } else {
                this.value = value;
            }
        });

        // Field-specific dynamic validation
        const validators = {
            cardholder: val => /^[a-zA-Z\s]+$/.test(val) || "Enter a valid name (letters and spaces only).",
            cardnumber: val => /^\d{16}$/.test(val.replace(/\s/g, "")) || "Card number must be 16 digits.",
            expiry: val => {
                if (!/^(0[1-9]|1[0-2])\/\d{2}$/.test(val)) return "Enter expiry in MM/YY.";
                const [month, year] = val.split('/');
                const expiryDate = new Date(`20${year}-${month}-01`);
                const now = new Date();
                now.setDate(1);
                return expiryDate >= now || "Card is expired.";
            },
            cvv: val => /^\d{3}$/.test(val) || "CVV must be 3 digits.",
            email: val => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(val) || "Invalid email format.",
            phone: val => /^\d{10}$/.test(val) || "Phone must be 10 digits."
        };

        fields.forEach(id => {
            const input = document.getElementById(id);
            input.addEventListener('input', () => {
                const result = validators[id](input.value.trim());
                if (result === true) clearError(input);
                else showError(input, result);
            });
        });

        // Final validation on submit
        completePaymentBtn.addEventListener('click', async function (e) {
            e.preventDefault();

            let hasError = false;
            fields.forEach(id => {
                const input = document.getElementById(id);
                const result = validators[id](input.value.trim());
                if (result === true) clearError(input);
                else {
                    showError(input, result);
                    hasError = true;
                }
            });

            if (hasError) return; // Stop if any invalid field

            try {
                const bookingId = "<%= bookingId %>";
                const response = await fetch("/payment", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ bookingId })
                });

                if (response.ok) {
                    window.location.href = `/review?bookingId=${bookingId}`;
                } else {
                    alert("Payment failed. Please try again.");
                }
            } catch (error) {
                console.error("Payment processing error:", error);
                alert("An error occurred while processing the payment.");
            }
        });
    });
    </script>
        
</body>
</html>