<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Your Profile</title>
  <link rel="stylesheet" href="/styles/seeker_profile.css">
</head>
<body>
  <div class="card">
    <!-- Home icon link -->
    <a href="/home" class="home-icon" title="Go to Homepage">
      <span class="home-icon-symbol">&#x1F3E0;</span>
    </a>
    
    <div class="relative">
      <img class="profile-pic" src="/pics/profile-picture.png" alt="Profile Picture">
    </div>

    <form action="/update-seeker-profile" method="POST">
      <div class="info">
        <h2><input type="text" name="name" value="<%= seeker.name %>" readonly></h2>
      </div>

      <div class="details">
        <p>
          <span class="icon">&#x260E;</span>
          <input type="text" name="mobilenumber" value="<%= seeker.mobilenumber %>" readonly>
        </p>
        <p>
          <span class="icon">&#x2709;</span>
          <input type="text" name="email" value="<%= seeker.email %>" readonly disabled>
        </p>
        <p>
          <span class="icon">&#x1F4CD;</span>
          <input type="text" name="address" value="<%= seeker.address %>" readonly>
        </p>
      </div>

      <button type="button" class="btn edit-btn" id="editBtn">Edit Profile</button>
      <button type="submit" class="btn edit-btn" id="saveBtn" style="display:none;">Save Changes</button>
    </form>

    <form action="/prevbookings" method="GET">
      <button type="submit" class="btn">View Previous Bookings</button>
    </form>      
  </div>

  <script>
  document.addEventListener('DOMContentLoaded', () => {
    const editBtn = document.getElementById('editBtn');
    const saveBtn = document.getElementById('saveBtn');
    const nameInput = document.querySelector('input[name="name"]');
    const mobileInput = document.querySelector('input[name="mobilenumber"]');

    const nameError = document.createElement('small');
    const mobileError = document.createElement('small');
    nameError.style.color = 'red';
    mobileError.style.color = 'red';
    nameInput.parentNode.appendChild(nameError);
    mobileInput.parentNode.appendChild(mobileError);

    editBtn.addEventListener('click', () => {
      nameInput.removeAttribute('readonly');
      mobileInput.removeAttribute('readonly');
      saveBtn.style.display = 'block';
      editBtn.style.display = 'none';
    });

    //live

    nameInput.addEventListener('input', () => {
      const name = nameInput.value.trim();
      if (!/^[A-Za-z ]+$/.test(name)) {
        nameError.textContent = "Name should only contain letters and spaces.";
        nameInput.style.borderColor = "red";
      } else {
        nameError.textContent = "";
        nameInput.style.borderColor = "green";
      }
    });

    mobileInput.addEventListener('input', () => {
      const mobile = mobileInput.value.trim();
      if (!/^\d*$/.test(mobile)) {
        mobileInput.value = mobile.replace(/\D/g, ''); // strip non-digits
      }
      if (mobile.length !== 10) {
        mobileError.textContent = "Mobile number must be exactly 10 digits.";
        mobileInput.style.borderColor = "red";
      } else {
        mobileError.textContent = "";
        mobileInput.style.borderColor = "green";
      }
    });

    // --- VALIDATION ON SAVE ---

    saveBtn.addEventListener('click', (e) => {
      const name = nameInput.value.trim();
      const mobile = mobileInput.value.trim();
      let errors = [];

      if (!/^[A-Za-z ]+$/.test(name)) {
        errors.push("Name should only contain letters and spaces.");
      }
      if (!/^\d{10}$/.test(mobile)) {
        errors.push("Mobile number should be exactly 10 digits.");
      }

      if (errors.length > 0) {
        alert(errors.join("\n"));
        e.preventDefault();
        return;
      }

      // Disable fields after save
      nameInput.setAttribute('readonly', 'true');
      mobileInput.setAttribute('readonly', 'true');
      saveBtn.style.display = 'none';
      editBtn.style.display = 'block';
      nameInput.style.borderColor = '';
      mobileInput.style.borderColor = '';
    });
  });
  </script>

  <script src="/javascript/seeker_profile.js"></script>
</body>
</html>