<h2>User Management</h2>
<table class="management-table">
  <thead>
    <tr>
      <th>Name</th>
      <th>Email</th>
      <th>Contact</th>
      <th>Services</th>
      <th>Certification</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% if (helpers.length === 0) { %>
      <tr>
        <td colspan="6">No helpers found.</td>
      </tr>
    <% } else { %>
      <% helpers.forEach(helper => { %>
        <tr>
          <td><%= helper.name %></td>
          <td><%= helper.email %></td>
          <td><%= helper.mobilenumber %></td>
          <td>
            <% if (helper.services.length > 0) { %>
              <%= helper.services.map(service => service.name).join(', ') %>
            <% } else { %>
              No services listed
            <% } %>
          </td>
          <td>
            <% if (helper.certifications.length > 0) { %>
              <% helper.certifications.forEach(cert => { %>
                <a href="/uploads/<%= cert %>" target="_blank">View</a><br>
              <% }) %>
            <% } else { %>
              No File
            <% } %>
          </td>
          <td>
            <% if (helper.approved) { %>
              <span class="approved">Approved ✅</span>
            <% } else { %>
              <button onclick="approveUser('<%= helper._id %>')">Approve</button>
              <button onclick="rejectUser('<%= helper._id %>')">Reject</button>
            <% } %>
          </td>
        </tr>
      <% }) %>
    <% } %>
  </tbody>
</table>


<style>
    .management-table {
  width: 100%;
  border-collapse: collapse;
  margin-bottom: 20px;
  font-size: 16px;
}

.management-table th, 
.management-table td {
  padding: 12px;
  text-align: left;
  border-bottom: 1px solid #ddd;
}

.management-table th {
  background-color: #007ea7;
  color: #fff;
  font-weight: 600;
}

.management-table tr:hover {
  background-color: #f1f1f1;
}

.management-table td a {
  color: #007ea7;
  text-decoration: none;
  font-weight: 500;
}

.management-table td a:hover {
  text-decoration: underline;
}

button {
  padding: 6px 12px;
  border: none;
  border-radius: 4px;
  font-size: 14px;
  cursor: pointer;
  transition: background-color 0.2s ease;
}

button:hover {
  opacity: 0.9;
}

button[onclick^="approveUser"] {
  background-color: #4caf50;
  color: #fff;
}

button[onclick^="rejectUser"] {
  background-color: #f44336;
  color: #fff;
}

.approved {
  color: #4caf50;
  font-weight: 500;
}

</style>