<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard - ServiceSphere</title>
  <link rel="stylesheet" href="/styles/adminDashboard.css"> 
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>
  <div class="dashboard-container">
    <!-- Sidebar -->
    <aside class="sidebar">
      <div class="sidebar-profile">
        <img src="/pics/profile-picture.png" alt="Admin Profile Picture">
        <h3>Admin</h3>
        <p>Administrator</p>
      </div>

      <nav>
        <ul>
          <li><a href="/admin/dashboard"><i class="fas fa-tachometer-alt"></i>Dashboard</a></li>
          <li><a href="/admin/users"><i class="fas fa-users"></i>User Management</a></li>
          <li><a href="/admin/services"><i class="fas fa-list"></i>Service Overview</a></li>
          <li><a href="/admin/earnings"><i class="fas fa-wallet"></i>Earnings Overview</a></li>
        </ul>
      </nav>

      <div class="sidebar-footer">
        <p>&copy; 2025 ServiceSphere</p>
        <p><a href="#">Privacy Policy</a> | <a href="#">Terms of Service</a></p>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="main-content">
      <header>
        <h1><%= title %></h1>
      </header>

      <div class="content">
        <% if (content) { %>
          <%- include(content) %>
        <% } %>
      </div>
    </main>
  </div>

  <script src="/javascript/adminDashboard.js"></script>
</body>
</html>