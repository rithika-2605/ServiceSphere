<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ServiceSphere - Seeker Registration</title>
  <link rel="stylesheet" href="/styles/seekerRegistration.css">
  <style>
    .error-text {
      color: red;
      font-size: 0.85em;
      margin-top: 4px;
      display: none;
    }
    .invalid {
      border-color: red;
    }
  </style>
</head>
<body>
  <script src="https://unpkg.com/@dotlottie/player-component@2.7.12/dist/dotlottie-player.mjs" type="module"></script>
  <dotlottie-player
    class="bg-animation"
    src="https://lottie.host/97ea0de2-8839-4b2e-92ce-455e8731f33c/WSoZpRrAis.lottie"
    background="transparent"
    speed="1"
    style="width: 700px; height: 700px; margin-top:100px;"
    loop autoplay>
  </dotlottie-player>

  <div class="registration-container">
    <h1>Join ServiceSphere as a Seeker</h1>

    <% if (error) { %>
      <div class="error-message"><%= error %></div>
    <% } %>

    <form id="seeker-registration-form" action="/signup/seeker" method="POST" novalidate>
      <!-- Full Name -->
      <div class="form-group">
        <label for="name">Full Name</label>
        <input type="text" id="name" name="name" placeholder="Enter your full name" value="<%= name || '' %>" required>
        <span class="error-text" id="name-error"></span>
      </div>

      <!-- Email -->
      <div class="form-group">
        <label for="email">Email Address</label>
        <input type="text" id="email" name="email" placeholder="Enter your email" value="<%= email || '' %>" required>
        <span class="error-text" id="email-error"></span>
      </div>

      <!-- Mobile -->
      <div class="form-group">
        <label for="mobilenumber">Mobile Number</label>
        <input type="tel" id="mobilenumber" name="mobilenumber" placeholder="Enter your Mobile Number" value="<%= mobilenumber || '' %>" required>
        <span class="error-text" id="mobile-error"></span>
      </div>

      <!-- Password -->
      <div class="form-group">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" placeholder="Create a password" required>
        <span class="error-text" id="password-error"></span>
      </div>

      <!-- Confirm Password -->
      <div class="form-group">
        <label for="confirm-password">Confirm Password</label>
        <input type="password" id="confirm-password" name="confirm_password" placeholder="Confirm your password" required>
        <span class="error-text" id="confirm-error"></span>
      </div>

      <!-- Address -->
      <div class="form-group">
        <label for="address">Address</label>
        <input type="text" id="address" name="address" placeholder="Enter your address" value="<%= address || '' %>">
        <span class="error-text" id="address-error"></span>
      </div>

      <div class="form-group">
        <button type="submit">Register</button>
      </div>
    </form>

    <p>Already a seeker? <a href="/login/seeker">Login here</a></p>
  </div>

  <script>
    const form = document.getElementById("seeker-registration-form");

    // Inputs
    const nameInput = document.getElementById("name");
    const emailInput = document.getElementById("email");
    const mobileInput = document.getElementById("mobilenumber");
    const passwordInput = document.getElementById("password");
    const confirmInput = document.getElementById("confirm-password");
    const addressInput = document.getElementById("address");

    // Error spans
    const nameError = document.getElementById("name-error");
    const emailError = document.getElementById("email-error");
    const mobileError = document.getElementById("mobile-error");
    const passwordError = document.getElementById("password-error");
    const confirmError = document.getElementById("confirm-error");
    const addressError = document.getElementById("address-error");

    // Regex Patterns
    const nameRegex = /^[A-Za-z\s]+$/;
    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    const mobileRegex = /^[0-9]{10}$/;
    const passwordRegex = /^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[\W_]).{8,}$/;

    // Validation Functions
    function validateName() {
      const val = nameInput.value.trim();
      if (!val) nameError.textContent = "Full name is required.";
      else if (!nameRegex.test(val)) nameError.textContent = "Only letters and spaces allowed.";
      else nameError.textContent = "";
      nameError.style.display = nameError.textContent ? "block" : "none";
      nameInput.classList.toggle("invalid", !!nameError.textContent);
      return !nameError.textContent;
    }

    function validateEmail() {
      const val = emailInput.value.trim();
      if (!val) emailError.textContent = "Email is required.";
      else if (!emailRegex.test(val)) emailError.textContent = "Invalid email format.";
      else emailError.textContent = "";
      emailError.style.display = emailError.textContent ? "block" : "none";
      emailInput.classList.toggle("invalid", !!emailError.textContent);
      return !emailError.textContent;
    }

    function validateMobile() {
      const val = mobileInput.value.trim();
      if (!val) mobileError.textContent = "Mobile number is required.";
      else if (!mobileRegex.test(val)) mobileError.textContent = "Must be a valid 10-digit number.";
      else mobileError.textContent = "";
      mobileError.style.display = mobileError.textContent ? "block" : "none";
      mobileInput.classList.toggle("invalid", !!mobileError.textContent);
      return !mobileError.textContent;
    }

    function validatePassword() {
      const val = passwordInput.value;
      if (!val) passwordError.textContent = "Password is required.";
      else if (!passwordRegex.test(val))
        passwordError.textContent = "Min 8 chars, one uppercase, lowercase, number, and symbol.";
      else passwordError.textContent = "";
      passwordError.style.display = passwordError.textContent ? "block" : "none";
      passwordInput.classList.toggle("invalid", !!passwordError.textContent);
      return !passwordError.textContent;
    }

    function validateConfirmPassword() {
      const val = confirmInput.value;
      if (!val) confirmError.textContent = "Please confirm your password.";
      else if (val !== passwordInput.value)
        confirmError.textContent = "Passwords do not match.";
      else confirmError.textContent = "";
      confirmError.style.display = confirmError.textContent ? "block" : "none";
      confirmInput.classList.toggle("invalid", !!confirmError.textContent);
      return !confirmError.textContent;
    }

    function validateAddress() {
      const val = addressInput.value.trim();
      if (!val) addressError.textContent = "Address is required.";
      else addressError.textContent = "";
      addressError.style.display = addressError.textContent ? "block" : "none";
      addressInput.classList.toggle("invalid", !!addressError.textContent);
      return !addressError.textContent;
    }

    // Real-time validation
    nameInput.addEventListener("input", validateName);
    emailInput.addEventListener("input", validateEmail);
    mobileInput.addEventListener("input", validateMobile);
    passwordInput.addEventListener("input", () => {
      validatePassword();
      validateConfirmPassword();
    });
    confirmInput.addEventListener("input", validateConfirmPassword);
    addressInput.addEventListener("input", validateAddress);

    // Final submit validation
    form.addEventListener("submit", (e) => {
      const valid =
        validateName() &&
        validateEmail() &&
        validateMobile() &&
        validatePassword() &&
        validateConfirmPassword() &&
        validateAddress();

      if (!valid) e.preventDefault();
    });
  </script>
</body>
</html>
