<!-- cart.ejs -->
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ServiceSphere - My Bookings</title>
    <link rel="stylesheet" href="/styles/cart.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.1.1/css/all.min.css">
</head>
<body>
    <div class="container">
        <header>
            <div class="header-content">
                <div class="page-title">
                    <h1>My Bookings</h1>
                    <p>Manage your confirmed service bookings</p>
                </div>
                <a href="/home" class="home-button">
                    <i class="fas fa-home"></i> Home
                </a>
            </div>
        </header>
        
        <main>
            <% if (bookings && bookings.length > 0) { %>
                <div class="bookings-container">
                    <% bookings.forEach(booking => { %>
                        <div class="booking-card" data-id="<%= booking.id %>">
                            <div class="booking-header">
                                <h3><%= booking.serviceType %></h3>
                                <div class="status-badge <%= booking.status.toLowerCase() %>">
                                    <%= booking.status %>
                                </div>
                            </div>
                            
                            <div class="booking-details">
                                <div class="helper-info">
                                    <i class="fas fa-user-circle"></i>
                                    <span><%= booking.helperName %></span>
                                </div>
                                
                                <div class="booking-time">
                                    <div class="time-item">
                                        <i class="fas fa-calendar"></i>
                                        <span><%= booking.date %></span>
                                    </div>
                                    <div class="time-item">
                                        <i class="fas fa-clock"></i>
                                        <span><%= booking.time %></span>
                                    </div>
                                </div>
                                
                                <div class="booking-cost">
                                    <span class="price">₹<%= booking.price.toFixed(2) %></span>
                                </div>
                            </div>
                            
                            <div class="booking-actions">
                                <% if (booking.status === 'Accepted' && !booking.paid) { %>
                                    <form action="/payment" method="GET">
                                        <input type="hidden" name="bookingId" value="<%= booking.id %>">
                                        <button type="submit" class="payment-btn">
                                            Complete Payment
                                        </button>
                                    </form>                                    
                                <% } else if (booking.status === 'Accepted' && booking.paid) { %>
                                    <div class="payment-status paid">
                                        <i class="fas fa-check-circle"></i> Payment Complete
                                    </div>
                                <% } else if (booking.status === 'Rejected') { %>
                                    <div class="payment-status rejected">
                                        <i class="fas fa-times-circle"></i> Booking Rejected
                                    </div>
                                <% } else { %>
                                    <div class="payment-status pending">
                                        <i class="fas fa-clock"></i> Awaiting Confirmation
                                    </div>
                                <% } %>
                            </div>
                        </div>
                    <% }); %>
                </div>
            <% } else { %>
                <div class="empty-state">
                    <i class="fas fa-shopping-cart"></i>
                    <h3>No bookings yet</h3>
                    <p>When you book services, they will appear here</p>
                    <a href="/search" class="browse-button">Browse Services</a>
                </div>
            <% } %>
        </main>
    </div>
    <script src="/javascript/cart.js" defer></script>
</body>
</html>