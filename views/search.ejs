<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Helper Profiles</title>
    <link rel="stylesheet" href="/styles/search.css">
</head>
<body>

    <!-- NAVBAR -->
    <div class="search-bar">
        <div class="logo-container">
            <img src="/pics/logo.png" alt="Service Sphere Logo" class="logo">
            <span class="company-name">Service Sphere</span>
        </div>
        <form id="searchForm">
            <input type="text" id="searchInput" placeholder="Search services...">
            <button type="submit" id="searchButton">Search</button>
        </form>
        <nav class="nav-icons">
            <a href="/profile" class="nav-icon"><svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24"><path fill="currentColor" d="M12 4a4 4 0 0 1 4 4a4 4 0 0 1-4 4a4 4 0 0 1-4-4a4 4 0 0 1 4-4m0 10c4.42 0 8 1.79 8 4v2H4v-2c0-2.21 3.58-4 8-4"/></svg></a>
            <a href="/cart" class="nav-icon"><svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24">
                <path fill="currentColor" d="M17 18c-1.11 0-2 .89-2 2a2 2 0 0 0 2 2a2 2 0 0 0 2-2a2 2 0 0 0-2-2M1 2v2h2l3.6 7.59l-1.36 2.45c-.15.28-.24.61-.24.96a2 2 0 0 0 2 2h12v-2H7.42a.25.25 0 0 1-.25-.25q0-.075.03-.12L8.1 13h7.45c.75 0 1.41-.42 1.75-1.03l3.58-6.47c.07-.16.12-.33.12-.5a1 1 0 0 0-1-1H5.21l-.94-2M7 18c-1.11 0-2 .89-2 2a2 2 0 0 0 2 2a2 2 0 0 0 2-2a2 2 0 0 0-2-2"/>
              </svg>
              </a>
        </nav>
    </div>
    <!-- NAVBAR ends -->

    <div class="container">
        <!-- Filters Section -->
        <div class="filters">
            <h2>Filters</h2>
            <form method="POST" action="/search">
                <div class="filter-section">
                    <h3>Price</h3>
                    <input type="range" name="priceRange" id="priceRange" min="2" max="1500" value="<%= typeof priceRange !== 'undefined' ? priceRange : 1500 %>">
                    <p>Max Price: ₹<span id="priceValue"><%= typeof priceRange !== 'undefined' ? priceRange : 1500 %></span></p>
                </div>
                <div class="filter-section">
                    <h3>Service Type</h3>
                    <select name="serviceTypeFilter" id="serviceTypeFilter">
                        <option value="all">All Services</option>
                    <% services.forEach(service => { %>
                        <option value="<%= service.name %>"><%= service.name %></option>
                    <% }) %>
                    </select>
                </div>
                <div class="filter-section">
                    <h3>Gender</h3>
                    <select name="genderFilter" id="genderFilter">
                        <option value="all" <%= genderFilter === 'all' ? 'selected' : '' %>>All</option>
                        <option value="male" <%= genderFilter === 'male' ? 'selected' : '' %>>Male</option>
                        <option value="female" <%= genderFilter === 'female' ? 'selected' : '' %>>Female</option>
                    </select>
                </div>
                <button type="submit">Apply Filters</button>
                <button type="button" id="resetFilters">Reset All</button>
            </form>
        </div>

        <!-- Services Section -->
        <div class="services">
            <h2>Services</h2>
            <div id="servicesList">
                <% if (helpers.length === 0) { %>
                    <p>No helpers found matching your criteria.</p>
                <% } else { %>
                    <% helpers.forEach(helper => { %>
                        <div class="service">
                            <div class="service-content">
                                <div class="service-details">
                                    <h3><%= helper.name %></h3>
                                    <p>Service: <%= helper.service %></p>
                                    <p>Price: ₹<%= helper.price || 'N/A' %></p>
                                    <p>Availability: <%= helper.availability %></p>
                                    <p>Gender: <%= helper.gender || 'N/A' %></p>
                                    <div class="service-rating">
                                        ⭐ <span><%= helper.rating || '4.5' %></span>
                                    </div>
                                    <form action="/booking" method="GET">
                                        <input type="hidden" name="helperId" value="<%= helper.id %>">
                                        <input type="hidden" name="servicetype" value="<%= helper.service %>">
                                        <input type="hidden" name="price" value="<%= helper.price %>">
                                        <button type="submit">Book Now</button>
                                    </form>                                      
                                </div>
                                <div class="service-image">
                                    <img src="/pics/profile-picture.png" alt="<%= helper.name %>">
                                </div>
                            </div>
                        </div>
                    <% }) %>
                <% } %>
            </div>            
        </div>
    </div>

    <%- include('partials/footer') %>


    <script src="/javascript/search.js"></script>
    <script>
        // Sync price slider display
        const priceRange = document.getElementById('priceRange');
        const priceValue = document.getElementById('priceValue');
        priceRange.addEventListener('input', () => {
            priceValue.textContent = priceRange.value;
        });

        // Reset filters
        document.getElementById('resetFilters').addEventListener('click', () => {
            window.location.href = '/search';
        });
    </script>
</body>
</html>
