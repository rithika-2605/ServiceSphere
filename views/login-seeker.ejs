<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ServiceSphere - Seeker Login</title>
  <link rel="stylesheet" href="/styles/seekerRegistration.css">
</head>
<body>
  <script src="https://unpkg.com/@dotlottie/player-component@2.7.12/dist/dotlottie-player.mjs" type="module"></script>
  <dotlottie-player class="bg-animation" src="https://lottie.host/97ea0de2-8839-4b2e-92ce-455e8731f33c/WSoZpRrAis.lottie" background="transparent" speed="1" style="width: 700px; height: 700px; margin-top:100px;" loop autoplay></dotlottie-player>

  <div class="registration-container">
    <h1>Login as a Seeker</h1>

    <% if (error) { %>
      <div class="error-message"><%= error %></div>
    <% } %>

    <form id="seeker-login-form" action="/login/seeker" method="POST">
      <div class="form-group">
        <label for="email">Email Address</label>
        <input type="email" id="email" name="email" placeholder="Enter your email" value="<%= email || '' %>" required>
      </div>

      <div class="form-group">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" placeholder="Enter your password" required>
      </div>

      <div class="form-group">
        <button type="submit">Login</button>
      </div>
    </form>
    <p>Don't have an account? <a href="/signup/seeker">Sign up here</a></p>
  </div>
</body>

</html>
